# Plugin-specific gitignore for development

# Dependencies and build artifacts
/vendor/
/node_modules/
composer.lock
package-lock.json

# Build outputs
vendor.zip
*.tar.gz
*.zip
/dist/
/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development and temporary files
*.backup
*.bak
*.orig
*.rej
*.tmp
*debug*
*test*
*Test*
*-test.*
*_test.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.buildpath
.settings/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Environment and config files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# PHP specific
.phpunit.result.cache
/phpunit.xml

# WordPress specific
wp-config-local.php
.htaccess.local