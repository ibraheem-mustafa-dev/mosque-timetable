<?xml version="1.0"?>
<ruleset name="Mosque Timetable (WP Pragmatic)">
  <!-- What to scan -->
  <file>public_html/wp-content/plugins/mosque-timetable/</file>

  <!-- Excludes -->
  <exclude-pattern>**/vendor/*</exclude-pattern>
  <exclude-pattern>**/node_modules/*</exclude-pattern>
  <exclude-pattern>**/dist/*</exclude-pattern>
  <exclude-pattern>**/build/*</exclude-pattern>
  <exclude name="Universal.Operators.DisallowShortTernary"/>

  <!-- One umbrella rule; easier to manage -->
  <rule ref="WordPress">
    <!-- Keep security ON -->
    <include-pattern>public_html/wp-content/plugins/mosque-timetable/*</include-pattern>

    <!-- Pragmatic relaxations (style-only) -->
    <exclude name="WordPress.PHP.YodaConditions"/>
    <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
    <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
    <exclude name="Generic.Commenting.DocComment.MissingShort"/>
    <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
    <exclude name="Generic.Strings.UnnecessaryStringConcat.Found"/>
    <exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_*"/>
    <exclude name="WordPress.PHP.DevelopmentFunctions.*"/>
    <exclude name="WordPress.DateTime.RestrictedFunctions.date_date"/>

    <!-- Quiet the two noisy ones explicitly -->
    <exclude name="Universal.Operators.DisallowShortTernary"/>
    <!-- Uncomment if you want to mute missing @param tags for now -->
    <!-- <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/> -->
  </rule>

  <!-- Optional PHPCompatibility (commented; enable if you want it) -->
  <!-- <rule ref="PHPCompatibilityWP"/> -->

  <!-- PHPCompat format wants a dash -->
  <config name="testVersion" value="8.3-"/>
  <config name="minimum_supported_wp_version" value="6.5"/>

  <arg name="extensions" value="php,php5,inc"/>
  <arg name="encoding" value="utf-8"/>
</ruleset>
