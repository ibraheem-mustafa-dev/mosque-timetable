{
  "name": "mosque-timetable/mosque-timetable-dev",
  "version": "3.0.1",
  "type": "project",
  "description": "WordPress site with Mosque Timetable plugin - Development Environment",
  "license": "GPL-2.0-or-later",
  "require-dev": {
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "php-parallel-lint/php-console-highlighter": "^1.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "vimeo/psalm": "^5.0",
    "php-stubs/wordpress-stubs": "^6.0",
    "php-stubs/wordpress-globals": "^0.2",
    "roave/security-advisories": "dev-master"
  },
  "scripts": {
    "dump": "composer dump-autoload -o",
  
    "lint": "php vendor/bin/parallel-lint --exclude vendor public_html/wp-content/plugins/mosque-timetable/",

    "lint:css": "npx stylelint 'public_html/wp-content/plugins/mosque-timetable/**/*.css'",

    "lint:js": "npx eslint public_html/wp-content/plugins/mosque-timetable/**/*.js",

    "phpstan": "php vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2G",

    "psalm": "php vendor/bin/psalm --show-info=true",

    "phpcs": "php -d memory_limit=2048M vendor/bin/phpcs -s -p",
    "phpcs:plugin": "php -d memory_limit=2048M vendor/bin/phpcs -s -p public_html/wp-content/plugins/mosque-timetable/",
    "phpcbf": "php -d memory_limit=2048M vendor/bin/phpcbf",
    "phpcbf:plugin": "php -d memory_limit=2048M vendor/bin/phpcbf public_html/wp-content/plugins/mosque-timetable/",
    "qa": [
      "@lint",
      "@phpcs:plugin",
      "@phpstan"
    ],
    "qa:fix": [
      "@phpcbf:plugin"
    ],
    "test": [
      "@qa"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true,
    "vendor-dir": "vendor"
  },
  "prefer-stable": true,
  "minimum-stability": "stable"
}
