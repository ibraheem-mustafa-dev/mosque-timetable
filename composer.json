{
  "name": "mosque-timetable/mosque-timetable-dev",
  "version": "3.0.1",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require-dev": {
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "php-parallel-lint/php-console-highlighter": "^1.0",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.2",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/wordpress-stubs": "^6.8",
    "php-stubs/wordpress-globals": "^0.2"
  },
  "scripts": {
    "lint": "php vendor/bin/parallel-lint --exclude vendor public_html/wp-content/plugins/mosque-timetable/",
    "phpstan": "php vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2G",
    "phpcs": "php vendor/bin/phpcs -p",
    "phpcbf": "php vendor/bin/phpcbf",
    "check": "@phpstan",
    "fix": "@phpcbf"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
