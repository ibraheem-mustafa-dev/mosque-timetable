<?xml version="1.0"?>
<ruleset name="Mosque Timetable — WordPress CS">
  <!-- Scan just the plugin -->
  <file>public_html/wp-content/plugins/mosque-timetable/</file>

  <!-- Exclude noise -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>

  <!-- Pure WordPress standard (includes Core + Extra + Docs) -->
  <rule ref="WordPress"/>

  <!-- Target WP version (tunes some sniffs) -->
  <config name="minimum_supported_wp_version" value="6.5"/>

  <!-- (Optional but recommended) enforce correct i18n text-domain -->
  <rule ref="WordPress.WP.I18n">
    <properties>
      <property name="text_domain" type="array" value="mosque-timetable"/>
    </properties>
  </rule>
</ruleset>
